---
import HowToBuyStep from '../components/HowToBuyStep.astro';
import data from '../data/how-to-buy.json';
---

<section id="como-adquirir" class="py-24 bg-brand-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-3">
        {data.badge}
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">{data.heading}</h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">{data.subtitle}</p>
    </div>

    <div class="relative">
      <!-- Linha conectora (desktop) -->
      <div
        class="hidden md:block absolute top-10 h-0.5 bg-gradient-to-r from-transparent via-accent/40 to-transparent"
        style="left: 16.66%; right: 16.66%;"
      ></div>

      <div class={`grid grid-cols-1 gap-8 ${data.steps.length === 3 ? 'md:grid-cols-3' : data.steps.length === 2 ? 'md:grid-cols-2' : 'md:grid-cols-4'}`}>
        {data.steps.map((step, i) => (
          <HowToBuyStep
            step={i + 1}
            icon={step.icon}
            title={step.title}
            description={step.description}
          />
        ))}
      </div>
    </div>

    <div class="text-center mt-14">
      <a href="#contato" class="btn-primary text-base inline-block">{data.cta_text}</a>
    </div>
  </div>
</section>
