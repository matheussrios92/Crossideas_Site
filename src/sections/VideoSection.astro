---
import video from '../data/video.json';
---

{video.youtube_id && (
  <section id="video" class="py-24 bg-brand-dark">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-3">
        {video.badge}
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">{video.heading}</h2>
      <p class="text-gray-400 text-lg mb-12 max-w-2xl mx-auto">{video.subtitle}</p>

      <div class="relative aspect-video rounded-2xl overflow-hidden shadow-2xl shadow-black/50">
        <iframe
          src={`https://www.youtube.com/embed/${video.youtube_id}?rel=0&modestbranding=1`}
          title={video.heading}
          class="absolute inset-0 w-full h-full"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>
)}
