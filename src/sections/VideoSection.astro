---
// Substituir pelo ID real do vídeo do YouTube quando disponível
const YOUTUBE_VIDEO_ID = 'dQw4w9WgXcQ';
---

<section id="video" class="py-24 bg-brand-dark">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <p class="text-accent font-semibold text-sm uppercase tracking-widest mb-3">
      Conheça Nosso Trabalho
    </p>
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
      Veja a Crossideas em Ação
    </h2>
    <p class="text-gray-400 text-lg mb-12 max-w-2xl mx-auto">
      Do modelo digital à peça física — assista ao nosso processo de impressão 3D e
      descubra o nível de detalhe que entregamos.
    </p>

    <!-- Video Embed -->
    <div class="relative aspect-video rounded-2xl overflow-hidden shadow-2xl shadow-black/50">
      <iframe
        src={`https://www.youtube.com/embed/${YOUTUBE_VIDEO_ID}?rel=0&modestbranding=1`}
        title="Vídeo de apresentação Crossideas"
        class="absolute inset-0 w-full h-full"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>

    <p class="text-gray-500 text-sm mt-6">
      ⚠️ Substitua o ID do vídeo em <code class="text-accent">VideoSection.astro</code> pelo vídeo real da Crossideas.
    </p>
  </div>
</section>
