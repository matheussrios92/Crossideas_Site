---
interface Props {
  step: number;
  title: string;
  description: string;
  icon: string;
}

const { step, title, description, icon } = Astro.props;
---

<div class="flex flex-col items-center text-center p-6 relative">
  <!-- Step Number + Icon -->
  <div class="relative mb-6">
    <div class="w-20 h-20 rounded-full bg-accent/10 border-2 border-accent flex items-center justify-center text-3xl">
      {icon}
    </div>
    <span class="absolute -top-2 -right-2 w-7 h-7 rounded-full bg-accent text-white text-xs font-bold flex items-center justify-center shadow">
      {step}
    </span>
  </div>

  <h3 class="text-xl font-bold text-white mb-3">{title}</h3>
  <p class="text-gray-400 text-sm leading-relaxed max-w-xs">{description}</p>
</div>
