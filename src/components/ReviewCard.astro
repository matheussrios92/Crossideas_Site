---
interface Props {
  name: string;
  role: string;
  body: string;
  rating: number;
}

const { name, role, body, rating } = Astro.props;
const stars = Array.from({ length: 5 }, (_, i) => i < rating);
---

<div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 flex flex-col gap-4 hover:shadow-md transition-shadow duration-200">
  <!-- Stars -->
  <div class="flex gap-1">
    {
      stars.map((filled) => (
        <svg
          class={`w-5 h-5 ${filled ? 'text-accent' : 'text-gray-300'}`}
          fill="currentColor"
          viewBox="0 0 20 20"
        >
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))
    }
  </div>

  <!-- Body -->
  <p class="text-[#374151] text-sm leading-relaxed flex-1">"{body}"</p>

  <!-- Author -->
  <div class="flex items-center gap-3 pt-2 border-t border-gray-100">
    <div class="w-10 h-10 rounded-full bg-accent/20 flex items-center justify-center text-accent font-bold text-base">
      {name.charAt(0).toUpperCase()}
    </div>
    <div>
      <p class="font-semibold text-brand-dark text-sm">{name}</p>
      <p class="text-xs text-[#6B7280]">{role}</p>
    </div>
  </div>
</div>
