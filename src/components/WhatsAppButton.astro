---
import site from '../data/site.json';

const MESSAGE = encodeURIComponent(site.whatsapp_message);
const WHATSAPP_URL = `https://wa.me/${site.whatsapp}?text=${MESSAGE}`;
---

<a
  href={WHATSAPP_URL}
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-6 right-6 z-50 group flex items-center gap-2"
  aria-label="Falar pelo WhatsApp"
>
  <!-- Tooltip -->
  <span
    class="hidden md:block bg-brand-dark text-white text-sm font-medium px-3 py-2 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap shadow-lg"
  >
    Solicitar Orçamento
  </span>

  <!-- Button -->
  <div
    class="w-14 h-14 bg-[#25D366] hover:bg-[#1da851] rounded-full flex items-center justify-center shadow-lg shadow-black/30 transition-transform duration-200 hover:scale-110 animate-bounce-subtle"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" class="w-7 h-7 fill-white">
      <path d="M16 0C7.164 0 0 7.163 0 16c0 2.82.736 5.463 2.017 7.76L0 32l8.48-2.008A15.93 15.93 0 0 0 16 32c8.837 0 16-7.163 16-16S24.837 0 16 0zm0 29.333a13.27 13.27 0 0 1-6.763-1.847l-.485-.287-5.03 1.19 1.21-4.895-.317-.503A13.262 13.262 0 0 1 2.667 16C2.667 8.636 8.636 2.667 16 2.667c7.363 0 13.333 5.97 13.333 13.333 0 7.364-5.97 13.333-13.333 13.333zm7.307-9.987c-.4-.2-2.368-1.168-2.735-1.3-.367-.133-.633-.2-.9.2-.267.4-1.033 1.3-1.267 1.567-.233.267-.467.3-.867.1-.4-.2-1.687-.622-3.213-1.98-1.187-1.058-1.987-2.365-2.22-2.765-.233-.4-.025-.616.175-.815.18-.18.4-.467.6-.7.2-.233.267-.4.4-.667.133-.267.067-.5-.033-.7-.1-.2-.9-2.168-1.233-2.967-.325-.779-.656-.673-.9-.685l-.767-.013c-.267 0-.7.1-1.067.5-.367.4-1.4 1.367-1.4 3.333s1.433 3.867 1.633 4.133c.2.267 2.82 4.3 6.833 6.033.954.413 1.7.66 2.28.844.958.306 1.832.263 2.522.159.77-.114 2.368-.968 2.702-1.903.333-.933.333-1.733.233-1.9-.1-.167-.367-.267-.767-.467z"/>
    </svg>
  </div>
</a>

<style>
  @keyframes bounce-subtle {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
  .animate-bounce-subtle {
    animation: bounce-subtle 2.5s ease-in-out infinite;
  }
</style>
